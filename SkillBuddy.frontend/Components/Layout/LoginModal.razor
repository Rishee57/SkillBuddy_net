<div class="modal fade custom-fade" id="loginModal" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 saas-modal shadow-lg">
            <!-- Refined Close Button (absolute top‑right) -->
            <button type="button" class="btn-saas-close" data-bs-dismiss="modal" aria-label="Close dialog">
                <i class="bi bi-x-lg"></i>
            </button>

            <div class="modal-body p-32">
                <!-- Icon Section -->
                <div class="icon-circle mb-16">
                    <i class="bi bi-telephone-fill"></i>
                </div>

                <!-- Header -->
                <h2 id="loginModalLabel" class="saas-title fw-bold mb-8">Enter your phone number</h2>
                <p class="saas-description mb-32">We'll send you a text with a verification code. Standard tariff may apply.</p>

                <!-- Phone Input Section -->
                <div class="combined-input-group mb-16">
                    <div class="country-selector" role="button" aria-label="Select country code" tabindex="0">
                        <span>+91</span>
                        <i class="bi bi-chevron-down ms-1"></i>
                    </div>
                    <div class="input-divider"></div>
                    <label for="phoneInput" class="visually-hidden">Phone number</label>
                    <input id="phoneInput" type="tel" 
                           class="saas-input" 
                           placeholder="Enter your phone number" 
                           @bind="phoneNumber" 
                           @bind:event="oninput" />
                </div>

                <!-- Continue Button -->
                <button class="btn btn-saas-continue mb-16" disabled="@IsContinueDisabled">
                    Continue
                </button>

                <!-- Footer Terms -->
                <p class="saas-terms text-center mb-0">
                    By continuing, you agree to our <a href="#">T&C</a> and <a href="#">Privacy</a> policy.
                </p>
                
                <div class="text-center mt-3">
                    <span class="saas-terms">Don't have an account? </span>
                    <a href="#" class="saas-terms fw-bold text-decoration-none">Register Now</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? phoneNumber;
    private bool IsContinueDisabled => string.IsNullOrWhiteSpace(phoneNumber);
}

<style>
