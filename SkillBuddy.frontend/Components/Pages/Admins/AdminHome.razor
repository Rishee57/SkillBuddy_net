@page "/admin"
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="admin-shell d-flex">
    <nav id="sidebar" class="sidebar bg-light border-end">
        <div class="sidebar-header p-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Brand</h5>
            <button class="btn btn-sm btn-outline-secondary d-md-none" @onclick="ToggleSidebar">✕</button>
        </div>
        <ul class="nav flex-column p-2">
            <li class="nav-item"><a class="nav-link" href="#">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Orders</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Customers</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Reports</a></li>
        </ul>
    </nav>

    <div class="main flex-grow-1">
        <header class="topbar border-bottom d-flex align-items-center justify-content-between px-3 py-2">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-primary me-2" id="sidebarToggle" @onclick="ToggleSidebar">☰</button>
                <h4 class="mb-0">Admin Home</h4>
            </div>
            <div>
                <ul class="nav nav-tabs" id="topTabs">
                    <li class="nav-item"><a class="nav-link active" href="#">Overview</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Sales</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Analytics</a></li>
                </ul>
            </div>
        </header>

        <div class="content p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card small-kpi">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <small class="text-muted">Amount processed</small>
                                    <div class="h5 mb-0">$23,567</div>
                                </div>
                                <canvas id="spark1" width="70" height="34"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card small-kpi">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <small class="text-muted">Amount spent</small>
                                    <div class="h5 mb-0">$14,552</div>
                                </div>
                                <canvas id="spark2" width="70" height="34"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card small-kpi">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <small class="text-muted">Profit processed</small>
                                    <div class="h5 mb-0">$31,156</div>
                                </div>
                                <canvas id="spark3" width="70" height="34"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Email sent</h5>
                        <div class="text-muted small">Timeline</div>
                    </div>
                    <div class="chart-large mt-3">
                        <canvas id="mainChart" height="140"></canvas>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-lg-7">
                    <div class="card p-3 h-100">
                        <h6>Traffic resources</h6>
                        <div class="row">
                            <div class="col-6">
                                <ul class="list-unstyled small">
                                    <li>Unique visitors: <strong>4,352</strong></li>
                                    <li>Page views: <strong>675</strong></li>
                                    <li>Pages/Visit: <strong>2.16</strong></li>
                                    <li>Bounce rate: <strong>67%</strong></li>
                                    <li>Visit: <strong>845</strong></li>
                                </ul>
                            </div>
                            <div class="col-6">
                                <div class="trend-rows">
                                    <div class="trend">⋯</div>
                                    <div class="trend">⋯</div>
                                    <div class="trend">⋯</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card p-3 h-100">
                        <h6>Reviews</h6>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex align-items-start mb-2">
                                <img src="images/avatar-placeholder.png" class="rounded-circle me-2" width="36" />
                                <div>
                                    <strong>Josephin Doe</strong>
                                    <div class="small text-muted">Lorem ipsum dolor sit amet</div>
                                </div>
                            </li>
                            <li class="d-flex align-items-start mb-2">
                                <img src="images/avatar-placeholder.png" class="rounded-circle me-2" width="36" />
                                <div>
                                    <strong>Luciano Dark</strong>
                                    <div class="small text-muted">Another short review</div>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="row mt-3 g-3">
                <div class="col-md-3">
                    <div class="tile card text-white bg-primary p-2"> <div class="card-body p-2"> <div class="h6">Users</div> <div class="h4">2,672</div> </div> </div>
                </div>
                <div class="col-md-3">
                    <div class="tile card text-white bg-success p-2"> <div class="card-body p-2"> <div class="h6">Earnings</div> <div class="h4">$6,391</div> </div> </div>
                </div>
                <div class="col-md-3">
                    <div class="tile card text-white bg-danger p-2"> <div class="card-body p-2"> <div class="h6">New Orders</div> <div class="h4">3,619</div> </div> </div>
                </div>
                <div class="col-md-3">
                    <div class="tile card text-white bg-warning p-2"> <div class="card-body p-2"> <div class="h6">Visitors</div> <div class="h4">9,276</div> </div> </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Campaign</th>
                                    <th>Client</th>
                                    <th>Changes</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Face Book ads</td>
                                    <td>Softtech</td>
                                    <td class="text-success">+4.6%</td>
                                    <td>Active</td>
                                    <td>3/04</td>
                                </tr>
                                <tr>
                                    <td>Youtube Videos</td>
                                    <td>Softtech</td>
                                    <td class="text-danger">-2.3%</td>
                                    <td>Closed</td>
                                    <td>3/04</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-lg-8">
                    <div class="card p-3">
                        <h6>Daily income</h6>
                        <canvas id="areaChart" height="80"></canvas>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card p-3 text-white map-card" style="background:#ff6b81;">
                        <h6 class="text-white">New York</h6>
                        <div class="map-placeholder">World map</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private bool sidebarCollapsed = false;
    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
        _ = JSRuntime.InvokeVoidAsync("adminHome.toggleSidebar", sidebarCollapsed);
    }
}
