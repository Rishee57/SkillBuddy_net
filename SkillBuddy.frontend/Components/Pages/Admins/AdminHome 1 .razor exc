@page "/admin"
@page "/admin/home"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

<PageTitle>Admin Dashboard - SkillBuddy</PageTitle>

<HeadContent>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="/css/admin-home.css" rel="stylesheet" />
</HeadContent>

<!-- Top Navigation Bar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-white shadow-sm fixed-top">
  <div class="container-fluid px-4">
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
      <i class="fas fa-bars text-dark"></i>
    </button>
    <div class="navbar-nav ms-auto">
      <div class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center text-dark" href="#" data-bs-toggle="dropdown">
          <i class="fas fa-user-circle me-2"></i>
          Admin
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i> Profile</a></li>
          <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2"></i> Settings</a></li>
          <li>
            <hr class="dropdown-divider">
          </li>
          <li><a class="dropdown-item" href="#"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
        </ul>
      </div>
    </div>
  </div>
</nav>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse">
      <div class="position-sticky pt-3">
        <div class="text-center py-4">
          <h5 class="fw-bold text-primary">SkillBuddy</h5>
        </div>
        <ul class="nav flex-column">
          <!-- Empty sidebar as requested -->
        </ul>
      </div>
    </nav>

    <!-- Main Dashboard Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
      <!-- Dashboard Header -->
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3">
        <h1 class="h2">Dashboard</h1>
      </div>

      <!-- Statistics Cards Row -->
      <div class="row mb-4">
        <!-- Blue Card -->
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-primary shadow h-100 py-2" style="border-left: 4px solid #4e73df;">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Revenue</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">$23,567</div>
                  <div class="mt-2">
                    <canvas id="blueChart" width="100" height="30"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Pink Card -->
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-info shadow h-100 py-2" style="border-left: 4px solid #e74a3b;">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-uppercase mb-1" style="color: #e74a3b;">Orders</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">$14,552</div>
                  <div class="mt-2">
                    <canvas id="pinkChart" width="100" height="30"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Orange Card -->
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-warning shadow h-100 py-2" style="border-left: 4px solid #f6c23e;">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Profit</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">$31,156</div>
                  <div class="mt-2">
                    <canvas id="orangeChart" width="100" height="30"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Green Card (placeholder for 4th card) -->
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-success shadow h-100 py-2" style="border-left: 4px solid #1cc88a;">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Growth</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">18.2%</div>
                  <div class="mt-2">
                    <canvas id="greenChart" width="100" height="30"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="row mb-4">
        <!-- Main Bar Chart -->
        <div class="col-lg-7">
          <div class="card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h6 class="m-0 font-weight-bold text-primary">Revenue Analytics</h6>
              <div class="dropdown no-arrow">
                <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="fas fa-ellipsis-v fa-sm fa-fw text-gray-400"></i>
                </a>
              </div>
            </div>
            <div class="card-body">
              <div class="chart-area">
                <canvas id="mainChart" width="100" height="40"></canvas>
              </div>
            </div>
          </div>
        </div>

        <!-- Colored Progress Cards -->
        <div class="col-lg-5">
          <div class="row">
            <div class="col-12 mb-3">
              <div class="card shadow"
                style="background: linear-gradient(90deg, #4e73df 0%, #224abe 100%); color: white;">
                <div class="card-body text-center">
                  <div class="text-white-50 small">Revenue</div>
                  <div class="h4 mb-0 text-white">2,672</div>
                </div>
              </div>
            </div>
            <div class="col-12 mb-3">
              <div class="card shadow"
                style="background: linear-gradient(90deg, #e74a3b 0%, #c0392b 100%); color: white;">
                <div class="card-body text-center">
                  <div class="text-white-50 small">Orders</div>
                  <div class="h4 mb-0 text-white">3,619</div>
                </div>
              </div>
            </div>
            <div class="col-12 mb-3">
              <div class="card shadow"
                style="background: linear-gradient(90deg, #1cc88a 0%, #17a673 100%); color: white;">
                <div class="card-body text-center">
                  <div class="text-white-50 small">Growth</div>
                  <div class="h4 mb-0 text-white">$6,391</div>
                </div>
              </div>
            </div>
            <div class="col-12 mb-3">
              <div class="card shadow"
                style="background: linear-gradient(90deg, #f6c23e 0%, #dda20a 100%); color: white;">
                <div class="card-body text-center">
                  <div class="text-white-50 small">Profit</div>
                  <div class="h4 mb-0 text-white">9,276</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Section with Data Tables -->
      <div class="row">
        <!-- Left Side - Revenue Chart -->
        <div class="col-lg-5">
          <div class="card shadow mb-4">
            <div class="card-header py-3">
              <h6 class="m-0 font-weight-bold text-primary">Revenue Source</h6>
            </div>
            <div class="card-body">
              <div class="chart-pie pt-4 pb-2">
                <canvas id="pieChart"></canvas>
              </div>
              <div class="mt-4 text-center small">
                <span class="mr-2"><i class="fas fa-circle text-primary"></i> Direct</span>
                <span class="mr-2"><i class="fas fa-circle text-success"></i> Social</span>
                <span class="mr-2"><i class="fas fa-circle text-info"></i> Referral</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side - Data Table -->
        <div class="col-lg-7">
          <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
              <h6 class="m-0 font-weight-bold text-primary">Recent Transactions</h6>
              <button class="btn btn-sm btn-primary">View All</button>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Position</th>
                      <th>Office</th>
                      <th>Age</th>
                      <th>Date</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Tiger Nixon</td>
                      <td>System Architect</td>
                      <td>Edinburgh</td>
                      <td>61</td>
                      <td>2011/04/25</td>
                      <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Garrett Winters</td>
                      <td>Accountant</td>
                      <td>Tokyo</td>
                      <td>63</td>
                      <td>2011/07/25</td>
                      <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Ashton Cox</td>
                      <td>Junior Technical Author</td>
                      <td>San Francisco</td>
                      <td>66</td>
                      <td>2009/01/12</td>
                      <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Cedric Kelly</td>
                      <td>Senior Javascript Developer</td>
                      <td>Edinburgh</td>
                      <td>22</td>
                      <td>2012/03/29</td>
                      <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Airi Satou</td>
                      <td>Accountant</td>
                      <td>Tokyo</td>
                      <td>33</td>
                      <td>2008/11/28</td>
                      <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Color Cards Row -->
      <div class="row mb-4">
        <div class="col-lg-3">
          <div class="card text-white mb-3" style="background: linear-gradient(90deg, #36b9cc 0%, #258391 100%);">
            <div class="card-body">
              <div class="text-white-50 small text-uppercase">Sales</div>
              <div class="h5 mb-0">43,678K</div>
            </div>
          </div>
        </div>
        <div class="col-lg-9">
          <!-- Bottom Large Chart -->
          <div class="card mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body text-white">
              <div class="d-flex justify-content-between">
                <div>
                  <div class="text-white-50 small">New York</div>
                  <div class="h5 mb-0">$5,765</div>
                </div>
                <div class="chart-area-bottom">
                  <canvas id="bottomChart" width="200" height="60"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/admin-charts.js"></script>

@code {
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      // Initialize charts and dashboard components
      await JS.InvokeVoidAsync("console.log", "Admin Dashboard loaded successfully");
    }
  }
}