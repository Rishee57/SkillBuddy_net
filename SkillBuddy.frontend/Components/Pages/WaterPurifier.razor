@page "/water-purifier"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components

<h1>Water purifier services</h1>

<div class="container py-4 service-page">
  <div class="row gx-4">
    <aside class="col-md-3 d-none d-md-block">
      <div class="mb-3">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title mb-1">Water Purifier</h5>
            <div class="small text-muted mb-2">4.78 <span class="text-secondary">(2.0M bookings)</span></div>
            <div class="badge bg-white border rounded-pill py-2 px-3 mb-3 d-inline-flex align-items-center warranty">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                <path d="M12 2l3 6 6 3-6 3-3 6-3-6-6-3 6-3 3-6z" fill="#f1f5f9"></path>
              </svg>
              <small class="mb-0">Up to 365 days warranty on Native spares</small>
            </div>
            <hr />
            <h6 class="mt-2">Select a service</h6>
            <div class="d-flex gap-2 mt-2 selector">
              <button class="selector-btn text-center" aria-pressed="false">
                <img src="/images/banners/banner1.svg" alt="Repair" />
                <div class="small mt-1">Repair</div>
              </button>
              <button class="selector-btn active text-center" aria-pressed="true">
                <img src="/images/banners/banner2.svg" alt="Service" />
                <div class="small mt-1">Service</div>
              </button>
              <button class="selector-btn text-center" aria-pressed="false">
                <img src="/images/banners/banner3.svg" alt="Install" />
                <div class="small mt-1">Installation</div>
              </button>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <main class="col-12 col-md-6">
      <section id="repair" class="mb-4">
        <h4>Repair</h4>
        <div class="service-list">
          <div class="service-card d-flex align-items-center">
            <div class="service-info flex-grow-1">
              <h5 class="mb-1">Water purifier check-up</h5>
              <div class="small text-muted">4.78 <span class="text-secondary">(146K reviews)</span> — <strong>Starts at
                  ₹299</strong></div>
              <p class="mb-0 mt-2 small text-muted">Complete check-up to identify issues before repair</p>
              <a href="#" class="small link-primary">View details</a>
            </div>
            <div class="service-thumb text-end ms-3">
              <img src="/images/banners/banner1.svg" alt="thumb" class="img-thumbnail" />
              <div class="mt-2"><button class="btn btn-add">Add</button></div>
            </div>
          </div>
        </div>
      </section>

      <section id="service" class="mb-4">
        <h4>Service</h4>
        <div class="service-list">
          <div class="service-card d-flex align-items-center">
            <div class="service-info flex-grow-1">
              <h5 class="mb-1">Water purifier filter check-up</h5>
              <div class="small text-muted">4.81 <span class="text-secondary">(138K reviews)</span> — ₹299 • 60 mins
              </div>
              <p class="mb-0 mt-2 small text-muted">Filters & RO membrane checked for performance</p>
              <a href="#" class="small link-primary">View details</a>
            </div>
            <div class="service-thumb text-end ms-3">
              <img src="/images/banners/banner2.svg" alt="thumb" class="img-thumbnail" />
              <div class="mt-2"><button class="btn btn-add">Add</button></div>
            </div>
          </div>

          <div class="service-card d-flex align-items-center">
            <div class="service-info flex-grow-1">
              <h5 class="mb-1">Water purifier regular service</h5>
              <div class="small text-muted">4.84 <span class="text-secondary">(19K reviews)</span> — ₹1,800 • 60 mins
              </div>
              <p class="mb-0 mt-2 small text-muted">Service with Native pre-filter, sediment & carbon filters</p>
              <a href="#" class="small link-primary">View details</a>
            </div>
            <div class="service-thumb text-end ms-3">
              <img src="/images/banners/banner3.svg" alt="thumb" class="img-thumbnail" />
              <div class="mt-2"><button class="btn btn-add">Add</button></div>
            </div>
          </div>

        </div>
      </section>

      <section id="install" class="mb-4">
        <h4>Installation / uninstallation</h4>
        <div class="service-list">
          <div class="service-card d-flex align-items-center">
            <div class="service-info flex-grow-1">
              <h5 class="mb-1">Water purifier installation</h5>
              <div class="small text-muted">4.81 <span class="text-secondary">(73K reviews)</span> — ₹450 • 60 mins
              </div>
              <a href="#" class="small link-primary">View details</a>
            </div>
            <div class="service-thumb text-end ms-3">
              <img src="/images/banners/banner1.svg" alt="thumb" class="img-thumbnail" />
              <div class="mt-2"><button class="btn btn-add">Add</button></div>
            </div>
          </div>

          <div class="service-card d-flex align-items-center">
            <div class="service-info flex-grow-1">
              <h5 class="mb-1">Water purifier uninstallation</h5>
              <div class="small text-muted">4.87 <span class="text-secondary">(12K reviews)</span> — ₹400 • 30 mins
              </div>
              <a href="#" class="small link-primary">View details</a>
            </div>
            <div class="service-thumb text-end ms-3">
              <img src="/images/banners/banner2.svg" alt="thumb" class="img-thumbnail" />
              <div class="mt-2"><button class="btn btn-add">Add</button></div>
            </div>
          </div>

        </div>
      </section>
    </main>

    <aside class="col-md-3 d-none d-md-block">
      <div class="card mb-3 p-3">
        <div class="small text-muted">No items in your cart</div>
      </div>
      <div class="card p-3">
        <h6>UC Promise</h6>
        <ul class="small">
          <li>Verified Professionals</li>
          <li>Hassle Free Booking</li>
          <li>Transparent Pricing</li>
        </ul>
      </div>
    </aside>
    <aside class="col-md-3 d-none d-md-block">
      <div class="mb-3">
        <div class="card shadow-sm p-3 text-center small cart-card">
          <img src="/images/icons/shopping-cart.svg" alt="cart" style="width:46px;height:46px;opacity:.95" />
          <div class="mt-2">No items in your cart</div>
        </div>
      </div>
      <div class="mb-3">
        <div class="card shadow-sm p-3 offer-card">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <div class="small text-muted">Save 10% on every …</div>
              <a href="#" class="link-primary">View More Offers</a>
            </div>
            <div><img src="/favicon.png" alt="plus" style="width:44px;height:44px" /></div>
          </div>
        </div>
      </div>
      <div>
        <div class="card shadow-sm p-3 promise-card">
          <h6>UC Promise</h6>
          <ul class="small mb-0">
            <li>Verified Professionals</li>
            <li>Hassle Free Booking</li>
            <li>Transparent Pricing</li>
          </ul>
        </div>
      </div>
    </aside>
  </div>
</div>
