            <span class="fw-semibold">4.78</span>
            <span class="text-muted">(146K reviews)</span>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <!-- UCover Standard Rate Card -->
        <div class="d-flex align-items-center justify-content-between p-3 mb-4 rounded-3"
          style="background: #f0f9ff; border: 1px solid #bae6fd;">
          <div class="d-flex align-items-center gap-3">
            <div style="color: #0ea5e9; font-weight: bold; font-size: 18px;">≈ UCover</div>
            <span class="fw-semibold">Standard rate card</span>
          </div>
          <svg width="20" height="20" fill="#6b7280" viewBox="0 0 24 24">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </div>

        <!-- Service Options Carousel -->
