            class="carousel-btn carousel-btn-left position-absolute d-flex align-items-center justify-content-center"
            style="left: -15px; top: 50%; transform: translateY(-50%); width: 32px; height: 32px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 50%; z-index: 10;">
            <svg width="16" height="16" fill="#6c757d" viewBox="0 0 24 24">
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </button>

          <!-- Service Cards Container -->
          @* CardsHorizontal.razor *@
          <div class="service-carousel-container" @ref="_container">
  <button class="carousel-btn carousel-btn-left" aria-label="Previous" @onclick="Prev">‹</button>
</div>
  <div class="service-carousel-track d-flex" @ref="_track">
    @if (Services is not null)
    {
      @foreach (var item in Services)
      {
        <div class="service-card">
          <div class="service-option">
            <div class="service-rating">★ @item.Rating.ToString("0.00", CultureInfo.InvariantCulture) (@item.ReviewsText)</div>
            <div class="service-title">@item.Title</div>
            <div class="service-price">₹@item.Price</div>
            <button class="btn btn-outline-primary btn-sm" @onclick="() => OnAdd.InvokeAsync(item)">Add</button>
          </div>
        </div>
      }
    }
  </div>

  <button class="carousel-btn carousel-btn-right" aria-label="Next" @onclick="Next">›</button>
</div>

