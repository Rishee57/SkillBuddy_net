  <!-- Modal used on small screens to show the chosen section -->
  <div class="modal fade" id="sectionModal" tabindex="-1" aria-labelledby="sectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="sectionModalLabel">Section</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <!-- content injected by site.js -->
        </div>
      </div>
    </div>
  </div>

  <!-- Categories grid (split into Home appliances & Kitchen appliances) -->
  <section class="mb-5">
    <h3 class="mb-3">Home appliances</h3>
    <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
      @foreach (var card in HomeAppliances)
      {
        <div class="col">
          <div class="service-tile text-center p-3 shadow-sm rounded-3 h-100" itemprop="service" itemscope
            itemtype="https://schema.org/Service">
            <div class="tile-icon mb-2 d-inline-block bg-white rounded-3 p-3">
              <img src="@card.Icon" alt="@card.Title" style="width:48px;height:48px;object-fit:contain;"
                itemprop="image" />
            </div>
            <div class="tile-label mt-2"><span itemprop="name">@card.Title</span></div>
          </div>
        </div>
      }
    </div>

    <h3 class="mb-3 mt-4">Kitchen appliances</h3>
    <div class="row row-cols-2 row-cols-md-4 g-3">
      @foreach (var card in KitchenAppliances)
      {
        <div class="col">
          @if (card.Title == "Water Purifier")
          {
            <a class="d-block text-decoration-none text-reset" href="/water-purifier">
              <div class="service-tile text-center p-3 shadow-sm rounded-3 h-100" itemprop="service" itemscope
                itemtype="https://schema.org/Service">
                <div class="tile-icon mb-2 d-inline-block bg-white rounded-3 p-3">
                  <img src="@card.Icon" alt="@card.Title" style="width:48px;height:48px;object-fit:contain;"
                    itemprop="image" />
                </div>
                <div class="tile-label mt-2"><span itemprop="name">@card.Title</span></div>
              </div>
            </a>
          }
          else
          {
            <div class="service-tile text-center p-3 shadow-sm rounded-3 h-100" itemprop="service" itemscope
              itemtype="https://schema.org/Service">
              <div class="tile-icon mb-2 d-inline-block bg-white rounded-3 p-3">
                <img src="@card.Icon" alt="@card.Title" style="width:48px;height:48px;object-fit:contain;"
                  itemprop="image" />
              </div>
              <div class="tile-label mt-2"><span itemprop="name">@card.Title</span></div>
            </div>
          }
        </div>
      }
    </div>
  </section>

  <!-- Why choose us / quick CTA -->
  <section class="py-4 bg-light rounded-3 text-center">
    <div class="container">
      <h4 class="fw-semibold">Why SkillBuddy?</h4>
      <p class="mb-0">Reliable pros, upfront pricing, and a 100% satisfaction guarantee.</p>
    </div>
  </section>
</div>
@code {
  private record Card(string Title, string Icon);
  private Card[] CategoryCards = new[] {
new Card("Plumbing","/images/icons/plumbing.svg"),
new Card("Cleaning","/images/icons/cleaning.svg"),
new Card("Electrician","/images/icons/electrician.svg"),
new Card("Salon","/images/icons/salon.svg"),
new Card("Appliances","/images/icons/appliances.svg"),
new Card("Painting","/images/icons/painting.svg"),
new Card("Pest Control","/images/icons/pest.svg"),
new Card("Carpentry","/images/icons/carpentry.svg"),
};

  private Card[] HomeAppliances = new[] {
new Card("AC","/images/icons/appliances.svg"),
new Card("Washing Machine","/images/icons/washing-machine.svg"),
new Card("Television","/images/icons/television.svg"),
new Card("Laptop","/images/icons/laptop.svg"),
new Card("Air Cooler","/images/icons/appliances.svg"),
new Card("Geyser","/images/icons/appliances.svg"),
};

  private Card[] KitchenAppliances = new[] {
new Card("Water Purifier","/images/icons/appliances.svg"),
new Card("Refrigerator","/images/icons/refrigerator.svg"),
new Card("Stove","/images/icons/appliances.svg"),
new Card("Microwave","/images/icons/microwave.svg"),
new Card("Chimney","/images/icons/chimney.svg"),
};

  // Show a specific section: scroll on desktop, open modal on small screens
  private Task ShowRepair() => ShowSection("repair");
  private Task ShowService() => ShowSection("service");
  private Task ShowInstall() => ShowSection("install");
  public async Task ShowSection(string id)
  {
    try
    {
      var width = await JS.InvokeAsync<int>("sb.getInnerWidth");
      if (width < 768)
      {
        await JS.InvokeVoidAsync("sb.showSectionModal", id);
      }
      else
      {
        await JS.InvokeVoidAsync("sb.scrollToSection", id);
      }
    }
    catch (Exception ex)
    {
      Console.Error.WriteLine($"ShowSection error: {ex.Message}");
    }
  }
}